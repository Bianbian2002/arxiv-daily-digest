<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Arxiv Daily Digest</title>
<style>
:root { --fg:#222; --muted:#777; --accent:#b0413e; --border:#e5e5e5; --bg:#fdfdfc; }
body { font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, sans-serif;
       max-width: 760px; margin: 3em auto; padding: 0 1.2em;
       color: var(--fg); background: var(--bg); line-height: 1.6; }
h1 { font-size: 1.6em; border-bottom: 2px solid var(--fg); padding-bottom: .3em; }
h2 { font-size: 1.05em; margin-top: 2em; color: #444; }
.sub { color: var(--muted); font-size: .92em; }
ul { padding-left: 0; list-style: none; }
li { margin: .45em 0; }
a { color: var(--fg); text-decoration: none; }
a:hover { color: var(--accent); }
.muted { color: var(--muted); font-size: .88em; }
.latest li { padding: .45em 0; border-bottom: 1px solid var(--border); }
.latest li:last-child { border-bottom: none; }
.score { float: right; color: var(--accent); font-variant-numeric: tabular-nums; }
.cta { display: inline-block; margin-top: .8em; color: var(--accent); font-size: .92em; }
footer { margin-top: 4em; color: var(--muted); font-size: .85em; text-align: center; }
</style>
</head>
<body>
<h1>Arxiv Daily Digest</h1>
<p class="sub">Personalized math.OC digest · optimization dynamics &amp; spectral optimizers · updated when arXiv posts.</p>

{% if latest and latest.papers %}
<h2>Latest — {{ latest.date }}</h2>
<ul class="latest">
{% for p in latest.papers[:5] %}
  <li>
    <span class="score">{{ "%.2f"|format(p.score) }}</span>
    <a href="https://arxiv.org/abs/{{ p.arxiv_id }}">{{ p.title }}</a>
    <div class="muted">{{ p.authors|join(", ")|truncate(90) }}</div>
  </li>
{% endfor %}
</ul>
<a class="cta" href="archive/{{ latest.date }}.html">→ full digest</a>
{% endif %}

<h2>Archive</h2>
<ul>
{% for d in archives %}
  <li><a href="archive/{{ d }}.html">{{ d }}</a></li>
{% endfor %}
</ul>

<footer>Generated by a scheduled Claude agent · <a href="https://github.com/Bianbian2002/arxiv-daily-digest">source</a></footer>
</body>
</html>
