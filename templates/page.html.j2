<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Arxiv Digest — {{ date }}</title>
<style>
:root { --fg:#222; --muted:#777; --accent:#b0413e; --border:#e5e5e5; --bg:#fdfdfc; --card:#f7f5ef; }
* { box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, sans-serif;
       max-width: 760px; margin: 3em auto; padding: 0 1.2em;
       color: var(--fg); background: var(--bg); line-height: 1.6; }
h1 { font-size: 1.5em; border-bottom: 2px solid var(--fg); padding-bottom: .3em; margin-bottom: .3em; }
.sub { color: var(--muted); font-size: .92em; margin-top: 0; }
.nav { margin-bottom: 2em; }
.nav a { color: var(--muted); text-decoration: none; font-size: .9em; }
.nav a:hover { color: var(--accent); }
.summary { background: var(--card); padding: 1em 1.2em; border-radius: 4px;
           margin: 1.5em 0 2em; font-size: .95em; color: #333; }
.paper { margin: 2em 0; padding-bottom: 1.6em; border-bottom: 1px solid var(--border); }
.paper:last-child { border-bottom: none; }
.score { float: right; font-weight: 600; color: var(--accent); font-size: .95em;
         font-variant-numeric: tabular-nums; }
.paper h2 { font-size: 1.1em; margin: 0 0 .35em; line-height: 1.35; font-weight: 600; }
.paper h2 a { color: var(--fg); text-decoration: none; }
.paper h2 a:hover { color: var(--accent); }
.meta { color: var(--muted); font-size: .88em; margin-bottom: .6em; }
.why { background: var(--card); border-left: 3px solid var(--accent);
       padding: .55em .85em; margin: .6em 0; font-size: .93em; color: #3a3a3a; }
.abstract { color: #444; font-size: .93em; }
.abstract.collapsed { max-height: 5.2em; overflow: hidden; position: relative; }
.abstract.collapsed::after { content: ""; position: absolute; bottom: 0; left: 0; right: 0;
                              height: 2em; background: linear-gradient(transparent, var(--bg)); }
details { font-size: .9em; margin-top: .4em; }
details summary { cursor: pointer; color: var(--muted); }
details[open] summary { color: var(--accent); }
footer { margin-top: 4em; color: var(--muted); font-size: .85em; text-align: center; }
</style>
</head>
<body>
<div class="nav"><a href="../index.html">← all digests</a></div>
<h1>Arxiv Daily Digest</h1>
<p class="sub">{{ date }} · math.OC &amp; cross-listed · optimization dynamics, spectral optimizers</p>

{% if summary %}<div class="summary">{{ summary }}</div>{% endif %}

{% for p in papers %}
<article class="paper">
  <span class="score" title="taste match">{{ "%.2f"|format(p.score) }}</span>
  <h2><a href="https://arxiv.org/abs/{{ p.arxiv_id }}">{{ p.title }}</a></h2>
  <div class="meta">{{ p.authors|join(", ") }} · arXiv:{{ p.arxiv_id }}{% if p.primary_category %} · {{ p.primary_category }}{% endif %}</div>
  {% if p.why %}<div class="why">{{ p.why }}</div>{% endif %}
  <details>
    <summary>abstract</summary>
    <div class="abstract">{{ p.abstract }}</div>
  </details>
</article>
{% endfor %}

<footer>Generated by a scheduled Claude agent · <a href="https://github.com/Bianbian2002/arxiv-daily-digest">source</a></footer>
</body>
</html>
